{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stock-journal-pro",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },

  "app": {
    "windows": [
      {
        "title": "stock-journal-pro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },

  "bundle": {
    "active": true,
    "targets": "all"
  }
}